generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model users {
  id                  Int          @id @default(autoincrement())
  name                String?      @db.VarChar(255)
  email               String       @unique @db.VarChar(255)
  role                String       @default("user") @db.VarChar(50)
  password_hash       String?      @db.VarChar(255)
  phone               String?      @db.VarChar(20)
  is_active           Boolean      @default(true)
  email_verified      Boolean      @default(false)
  email_notifications Boolean      @default(true)
  token_version       Int          @default(0)      // Increment to revoke all JWTs for this user
  created_at          DateTime     @default(now()) @db.Timestamp(0)
  updated_at          DateTime     @default(now()) @updatedAt

  sessions    sessions[]
  login_logs  login_logs[]
}

model sessions {
  id            Int      @id @default(autoincrement())
  user_id       Int
  session_token String   @unique @db.VarChar(255)
  expires_at    DateTime @db.DateTime(0)
  created_at    DateTime @default(now()) @db.Timestamp(0)

  users users @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
}

model login_logs {
  id         Int      @id @default(autoincrement())
  user_id    Int?
  email      String   @db.VarChar(255)
  status     String   @db.VarChar(20)
  ip_address String?  @db.VarChar(45)
  user_agent String?  @db.Text
  created_at DateTime @default(now()) @db.Timestamp(0)

  users users? @relation(fields: [user_id], references: [id], onDelete: SetNull)

  @@index([user_id])
  @@index([email])
  @@index([created_at])
}

model contact_messages {
  id         Int      @id @default(autoincrement())
  name       String   @db.VarChar(100)
  email      String   @db.VarChar(255)
  phone      String?  @db.VarChar(30)
  message    String   @db.Text
  is_read    Boolean  @default(false)
  created_at DateTime @default(now()) @db.Timestamp(0)

  @@index([is_read])
  @@index([created_at])
}

model visits {
  id               Int      @id @default(autoincrement())
  ip_address       String?  @db.VarChar(45)
  user_agent       String?  @db.Text
  referrer         String?  @db.VarChar(500)
  visitor_name     String?  @db.VarChar(255)
  visitor_email    String?  @db.VarChar(255)
  device_type      String?  @db.VarChar(20)
  is_bounce        Boolean  @default(true)          
  session_duration Int?                              
  visited_at       DateTime @default(now()) @db.Timestamp(0)

  page_views page_views[]

  @@index([visited_at])
}

model page_views {
  id        Int      @id @default(autoincrement())
  page_path String   @db.VarChar(255)
  visit_id  Int?
  viewed_at DateTime @default(now()) @db.Timestamp(0)

  visits visits? @relation(fields: [visit_id], references: [id], onUpdate: Restrict)

  @@index([visit_id])
  @@index([page_path])
}

model hero_section {
  id              Int      @id @default(autoincrement())
  base_image      String   @db.VarChar(500)
  hover_image     String   @db.VarChar(500)
  title           String   @default("Dalis Studio") @db.VarChar(255)
  updated_at      DateTime @default(now()) @updatedAt
}

model quote_bracket_image {
  id              Int      @id @default(autoincrement())
  bracket_group   Int                        // 1, 2, or 3
  image_url       String   @db.VarChar(500)
  sort_order      Int      @default(0)
  created_at      DateTime @default(now()) @db.Timestamp(0)

  @@index([bracket_group, sort_order])
}

model signature_work {
  id              Int      @id @default(autoincrement())
  title           String   @db.VarChar(255)
  description     String   @db.Text
  image_url       String   @db.VarChar(500)
  sort_order      Int      @default(0)
  created_at      DateTime @default(now()) @db.Timestamp(0)
  updated_at      DateTime @default(now()) @updatedAt
}

model works_grid_item {
  id              Int      @id @default(autoincrement())
  title           String   @db.VarChar(255)
  description     String   @db.Text
  image_url       String   @db.VarChar(500)
  width_class     String   @db.VarChar(20)   // e.g. "w-56"
  height_class    String   @db.VarChar(20)   // e.g. "h-64"
  top_class       String   @db.VarChar(30)   // e.g. "top-[40%]"
  left_class      String   @db.VarChar(30)   // e.g. "left-[12%]"
  z_index         Int      @default(10)
  ambient_dark    String   @db.VarChar(100)  // e.g. "from-emerald-950 to-neutral-950"
  ambient_light   String   @db.VarChar(100)  // e.g. "from-emerald-100 via-white to-white"
  sort_order      Int      @default(0)
  created_at      DateTime @default(now()) @db.Timestamp(0)
  updated_at      DateTime @default(now()) @updatedAt
}

model about_hero {
  id                    Int      @id @default(autoincrement())
  base_image_dark       String   @db.VarChar(500)
  hover_image_dark      String   @db.VarChar(500)
  base_image_light      String   @db.VarChar(500)
  hover_image_light     String   @db.VarChar(500)
  updated_at            DateTime @default(now()) @updatedAt
}

model about_quote_image {
  id              Int      @id @default(autoincrement())
  position        String   @db.VarChar(10)   // "one", "two", "three"
  image_url       String   @db.VarChar(500)
  updated_at      DateTime @default(now()) @updatedAt

  @@unique([position])
}

model contact_content {
  id              Int      @id @default(autoincrement())
  card_image_url  String   @db.VarChar(500)
  showreel_url    String   @db.VarChar(500)
  updated_at      DateTime @default(now()) @updatedAt
}